{
  "name": "myblog-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "typecheck:strict:phase1": "vue-tsc -p tsconfig.strict.phase1.json --noEmit --pretty",
    "typecheck:strict:phase1:ci": "vue-tsc -p tsconfig.strict.phase1.json --noEmit --pretty false",
    "typecheck:strict:phase2": "vue-tsc -p tsconfig.strict.phase2.json --noEmit --pretty",
    "typecheck:strict:phase2:ci": "vue-tsc -p tsconfig.strict.phase2.json --noEmit --pretty false",
    "typecheck:strict:phase3": "vue-tsc -p tsconfig.strict.phase3.json --noEmit --pretty",
    "typecheck:strict:phase3:ci": "vue-tsc -p tsconfig.strict.phase3.json --noEmit --pretty false",
    "typecheck:strict:phase4": "vue-tsc -p tsconfig.strict.phase4.json --noEmit --pretty",
    "typecheck:strict:phase4:ci": "vue-tsc -p tsconfig.strict.phase4.json --noEmit --pretty false",
    "css:audit": "node ./scripts/check-hardcoded-colors.mjs",
    "css:imports:audit": "node ./scripts/check-duplicate-style-imports.mjs",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.8.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/mdc": "^0.19.2",
    "@nuxtjs/seo": "^3.0.0",
    "@pinia/nuxt": "^0.5.1",
    "@tailwindcss/typography": "^0.5.19",
    "@vueuse/core": "^14.1.0",
    "autoprefixer": "^10.4.23",
    "browser-image-compression": "^2.0.2",
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.25",
    "keen-slider": "^6.8.6",
    "md-editor-v3": "^6.3.1",
    "mermaid": "^11.12.2",
    "naive-ui": "^2.43.2",
    "nuxt": "^4.3.0",
    "nuxt-vitalizer": "^2.0.0",
    "pinia": "^2.1.7",
    "pixi.js": "^8.12.0",
    "postcss": "^8.5.6",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@bg-dev/nuxt-naiveui": "^2.0.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "latest",
    "@types/node": "latest",
    "cssnano": "^7.1.2",
    "sass": "^1.75.0",
    "tailwindcss": "^3.4.19",
    "typescript": "latest",
    "vue-tsc": "latest"
  }
}
